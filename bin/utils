#!/bin/bash

sshm0_install() {
  if [ ! -d "$SSHM0_CONFIG_DIR/servers" ]; then
    mkdir -p "$SSHM0_CONFIG_DIR/servers";
  fi
  if [ ! -f "$SSHM0_CONFIG_DIR/config" ]; then
    cp "$SSHM0_ROOT_DIR/config.dist" "$SSHM0_CONFIG_DIR/config";
  fi
}

sshm0_migrate() {
    local _config="$SSHM0_CONFIG_DIR/config"
    if [ ! -f "$_config" ]; then
        return 0
    fi

    source "$_config"

    if [ "${sshm0_config_version:-0}" -ge 2 ]; then
        return 0
    fi

    log "Migrating config to version 2..." 1

    if ! grep -q "sshm0_config_version" "$_config"; then
        printf 'sshm0_config_version=2\n' | cat - "$_config" > "$_config.tmp" && mv "$_config.tmp" "$_config"
    fi

    if ! grep -q "declare -A" "$_config"; then
        sed -i 's/declare -a/declare -A/' "$_config"
    fi

    log "Migration complete." 1
}

sshm0_get_plugin() {
  # shellcheck source=../config.dist
  source "$SSHM0_CONFIG_DIR/config";

  if [ "${sshm0_plugins[$1]}" != "" ]; then
    echo "${sshm0_plugins[$1]}";
    return 0;
  else
    return 1;
  fi
}

sshm0_get_plugin_list() {
  # shellcheck source=../config.dist
  source "$SSHM0_CONFIG_DIR/config";
  
  for plugin in "${!sshm0_plugins[@]}"; do
    echo -e "$1$plugin$2";
  done
}

sshm0_server_config_path() {
  if [[ ! "$1" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo "Error: invalid server name '$1' — only alphanumeric, dots, hyphens, and underscores allowed" >&2
    return 1
  fi
  echo "$SSHM0_CONFIG_DIR/servers/$1"
}

sshm0_server_exists() {
  local _path
  _path="$(sshm0_server_config_path "$1")" || return 1
  if [ ! -f "$_path" ]; then
    return 1
  else
    return 0
  fi
}

sshm0_load_server() {
  local _path
  _path="$(sshm0_server_config_path "$1")" || return 1
  if [ ! -f "$_path" ]; then
    return 1
  fi
  set -a
  source "$_path"
  set +a
  return 0
}

sshm0_record_connection() {
  local _history_file="$SSHM0_CONFIG_DIR/history"
  local _timestamp
  _timestamp="$(date +%s)"
  echo "${_timestamp}:$1" >> "$_history_file"
}
