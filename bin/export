#!/bin/bash

# @parseArger-begin
# @parseArger-help "export SSH config for all managed servers" --option "help" --short-option "h"
# @parseArger-version "0.3.1" --option "version" --short-option "v"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
# @parseArger-source $SSHM0_ROOT_DIR/bin/utils
source "$SSHM0_ROOT_DIR/bin/utils";
# @parseArger-declarations
# @parseArger opt output "output file path" --short o --default-value "$HOME/.ssh/config.d/sshm0"
# @parseArger flag merge "append to file instead of overwriting"
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options='o'
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
# OPTIONALS ARGUMENTS
_arg_output="$HOME/.ssh/config.d/sshm0"
# FLAGS
_arg_merge="off"
# NESTED
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "export SSH config for all managed servers:"
	echo -e "	-o, --output <output>: output file path [default: '$HOME/.ssh/config.d/sshm0']"
	echo -e "	--merge|--no-merge: append to file instead of overwriting"
	echo -e "Usage :
	$0 [--output <value>] [--[no-]merge]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="\033[0;31m";
				;;
			-2)
				_arg_COLOR="\033[0;33m";
				;;
			-1)
				_arg_COLOR="\033[1;33m";
				;;
			1)
				_arg_COLOR="\033[0;32m";
				;;
			2)
				_arg_COLOR="\033[1;36m";
				;;
			3)
				_arg_COLOR="\033[0;36m";
				;;
			*)
				_arg_COLOR="\033[0m";
				;;
		esac
		echo -e "${_arg_COLOR}${_arg_msg}\033[0m";
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			-o|--output)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_output="$2"
				shift
				;;
			--output=*)
				_arg_output="${_key##--output=}"
				;;
			-o*)
				_arg_output="${_key##-o}"
				;;
			
			--merge)
				_arg_merge="on"
				;;
			--no-merge)
				_arg_merge="off"
				;;
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			-v|--version)
				print_version;
				exit 0;
				;;
			-v*)
				print_version;
				exit 0;
				;;
			--verbose)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level + 1))";
					else
						_verbose_level="$2";
						shift;
					fi
					;;
				--quiet)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level - 1))";
					else
						_verbose_level="-$2";
						shift;
					fi
					;;
				
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string=""
	if [ "${_positionals_count}" -gt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 0, but got ${_positionals_count} (the last one was: '${_last_positional}').\n\t${_positionals[*]}" 1
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names=""
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	output: ${_arg_output}";
	echo -e "	merge: ${_arg_merge}";

}


print_version()
{
	echo "0.3.1";
}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 0 "${_positionals[@]}";
trap on_interrupt INT;



# @parseArger-parsing-end
# print_debug "$@"
# @parseArger-end

# --- export logic ---

_output_dir="$(dirname "$_arg_output")"
if [ ! -d "$_output_dir" ]; then
	mkdir -p "$_output_dir" || die "Failed to create output directory: $_output_dir" 1
fi

_tmpfile="$(mktemp)" || die "Failed to create temporary file" 1

{
	echo "# SSH Config — generated by sshm0 on $(date)"
	echo ""

	_server_count=0
	for _server_config in "$SSHM0_CONFIG_DIR/servers/"*; do
		[ -e "$_server_config" ] || continue
		_name="$(basename "$_server_config")"

		# Reset server variables to defaults before sourcing
		sshm0_server_ip=""
		sshm0_server_user=""
		sshm0_server_port=22
		sshm0_server_auth=""
		sshm0_server_password=""
		sshm0_server_key=""
		sshm0_server_cd=""
		sshm0_server_exec_before=()
		sshm0_server_group=""

		# shellcheck source=/dev/null
		source "$_server_config"

		echo "# Managed by sshm0 — do not edit manually"
		if [ -n "$sshm0_server_group" ]; then
			echo "# Group: $sshm0_server_group"
		fi
		echo "Host $_name"
		echo "    HostName $sshm0_server_ip"
		echo "    User $sshm0_server_user"
		echo "    Port $sshm0_server_port"

		if [ "$sshm0_server_auth" = "key" ] && [ -n "$sshm0_server_key" ]; then
			echo "    IdentityFile $sshm0_server_key"
		fi

		if [ "$sshm0_server_auth" = "password" ]; then
			echo "    # Password auth: use 'sshm0 connect $_name'"
		fi

		echo "    # Timeout: ${sshm0_server_timeout:-10}s"

		echo ""
		_server_count=$((_server_count + 1))
	done

	if [ "$_server_count" -eq 0 ]; then
		echo "# No servers configured"
	fi
} > "$_tmpfile"

if [ "$_arg_merge" = "on" ]; then
	cat "$_tmpfile" >> "$_arg_output"
else
	mv "$_tmpfile" "$_arg_output" || { rm -f "$_tmpfile"; die "Failed to write to $_arg_output" 1; }
	_tmpfile=""
fi

[ -n "$_tmpfile" ] && rm -f "$_tmpfile"

echo "$_arg_output"
