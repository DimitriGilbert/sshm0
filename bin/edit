#!/bin/bash

# @parseArger-begin
# @parseArger-help "edit a server" --option "help" --short-option "h"
# @parseArger-version "0.3.1" --option "version" --short-option "v"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
# @parseArger-source $SSHM0_ROOT_DIR/bin/utils
source "$SSHM0_ROOT_DIR/bin/utils";
# @parseArger-declarations
# @parseArger pos name "server name" --complete-custom "/usr/bin/ls /home/didi/.config/sshm0/servers"
# @parseArger opt ip "ip address"
# @parseArger opt user "username"
# @parseArger opt password "user password for the server" --short p
# @parseArger opt key "ssh private key" --short i --complete-custom "/usr/bin/ls /home/didi/.ssh"
# @parseArger opt auth "authentication type" --one-of "" --one-of "key" --one-of "password"
# @parseArger opt port "ssh port"
# @parseArger flag connect "connect to server" --short c
# @parseArger opt tag "comma-separated tags" --short t
# @parseArger opt proxy "proxy jump server name" --short J
# @parseArger opt timeout "connection timeout in seconds"
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options=''
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
_arg_name="";
# OPTIONALS ARGUMENTS
_arg_ip=
_arg_user=
_arg_password=
_arg_key=
_arg_auth=
_one_of_arg_auth=("" "key" "password" );
_arg_port=
_arg_tag=
_arg_group=
_arg_proxy=
_arg_timeout=
# FLAGS
_arg_connect="off"
# NESTED
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "edit a server:"
	echo -e "	name: server name"
	echo -e "	--ip <ip>: ip address"
	echo -e "	--user <user>: username"
	echo -e "	-p, --password <password>: user password for the server"
	echo -e "	-i, --key <key>: ssh private key"
	echo -e "	--auth <auth>: authentication type [one of '' 'key' 'password']"
	echo -e "	--port <port>: ssh port"
	echo -e "	-c|--connect|--no-connect: connect to server"
	echo -e "	-t, --tag <tag>: comma-separated tags"
	echo -e "	-J, --proxy <proxy>: proxy jump server name"
	echo -e "	--timeout <timeout>: connection timeout in seconds"
	echo -e "	-g, --group <group>: server group"
	echo -e "Usage :
	$0 <name> [--ip <value>] [--user <value>] [--password <value>] [--key <value>] [--auth <value>] [--port <value>] [--tag <value>] [--group <value>] [--proxy <value>] [--timeout <value>] [--[no-]connect]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="\033[0;31m";
				;;
			-2)
				_arg_COLOR="\033[0;33m";
				;;
			-1)
				_arg_COLOR="\033[1;33m";
				;;
			1)
				_arg_COLOR="\033[0;32m";
				;;
			2)
				_arg_COLOR="\033[1;36m";
				;;
			3)
				_arg_COLOR="\033[0;36m";
				;;
			*)
				_arg_COLOR="\033[0m";
				;;
		esac
		echo -e "${_arg_COLOR}${_arg_msg}\033[0m";
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			--ip)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_ip="$2"
				shift
				;;
			--ip=*)
				_arg_ip="${_key##--ip=}"
				;;
			
			--user)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_user="$2"
				shift
				;;
			--user=*)
				_arg_user="${_key##--user=}"
				;;
			
			-p|--password)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_password="$2"
				shift
				;;
			--password=*)
				_arg_password="${_key##--password=}"
				;;
			-p*)
				_arg_password="${_key##-p}"
				;;
			
			-i|--key)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_key="$2"
				shift
				;;
			--key=*)
				_arg_key="${_key##--key=}"
				;;
			-i*)
				_arg_key="${_key##-i}"
				;;
			
			--auth)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_auth="$2"
				if [[ "${#_one_of_arg_auth[@]}" -gt 0 ]];then [[ "${_one_of_arg_auth[*]}" =~ (^|[[:space:]])"$_arg_auth"($|[[:space:]]) ]] || die "auth must be one of:  key password";fi
				shift
				;;
			--auth=*)
				_arg_auth="${_key##--auth=}"
				if [[ "${#_one_of_arg_auth[@]}" -gt 0 ]];then [[ "${_one_of_arg_auth[*]}" =~ (^|[[:space:]])"$_arg_auth"($|[[:space:]]) ]] || die "auth must be one of:  key password";fi
				;;
			
			--port)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_port="$2"
				shift
				;;
			--port=*)
				_arg_port="${_key##--port=}"
				;;
			
			-t|--tag)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_tag="$2"
				shift
				;;
			--tag=*)
				_arg_tag="${_key##--tag=}"
				;;
			-t*)
				_arg_tag="${_key##-t}"
				;;
			
			--timeout)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_timeout="$2"
				shift
				;;
			--timeout=*)
				_arg_timeout="${_key##--timeout=}"
				;;
			
			-g|--group)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_group="$2"
				shift
				;;
			--group=*)
				_arg_group="${_key##--group=}"
				;;
			-g*)
				_arg_group="${_key##-g}"
				;;
			
			-J|--proxy)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_proxy="$2"
				shift
				;;
			--proxy=*)
				_arg_proxy="${_key##--proxy=}"
				;;
			-J*)
				_arg_proxy="${_key##-J}"
				;;
			
			-c|--connect)
				_arg_connect="on"
				;;
			--no-connect)
				_arg_connect="off"
				;;
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			-v|--version)
				print_version;
				exit 0;
				;;
			-v*)
				print_version;
				exit 0;
				;;
			--verbose)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level + 1))";
					else
						_verbose_level="$2";
						shift;
					fi
					;;
				--quiet)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level - 1))";
					else
						_verbose_level="-$2";
						shift;
					fi
					;;
				
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string="name"
	if [ "${_positionals_count}" -gt 1 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 1 (namely: $_required_args_string), but got ${_positionals_count} (the last one was: '${_last_positional}').\n\t${_positionals[*]}" 1
	fi
	if [ "${_positionals_count}" -lt 1 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: Not enough positional arguments - we require at least 1 (namely: $_required_args_string), but got only ${_positionals_count}.
	${_positionals[*]}" 1;
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names="_arg_name ";
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	name: ${_arg_name}";
	echo -e "	ip: ${_arg_ip}";
	echo -e "	user: ${_arg_user}";
	echo -e "	password: ${_arg_password}";
	echo -e "	key: ${_arg_key}";
	echo -e "	auth: ${_arg_auth}";
	echo -e "	port: ${_arg_port}";
	echo -e "	connect: ${_arg_connect}";
	echo -e "	tag: ${_arg_tag}";
	echo -e "	timeout: ${_arg_timeout}";
	echo -e "	group: ${_arg_group}";
	echo -e "	proxy: ${_arg_proxy}";

}


print_version()
{
	echo "0.3.1";
}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 1 "${_positionals[@]}";
trap on_interrupt INT;



# @parseArger-parsing-end
# print_debug "$@"
# @parseArger-end


if sshm0_load_server "$_arg_name"; then
#shellcheck source=../server.dist
	if [ -z "$_arg_ip" ] && [ -z "$_arg_user" ] && [ -z "$_arg_password" ] && [ -z "$_arg_key" ] && [ -z "$_arg_auth" ] && [ -z "$_arg_port" ] && [ -z "$_arg_tag" ] && [ -z "$_arg_group" ] && [ -z "$_arg_proxy" ] && [ -z "$_arg_timeout" ]; then
		echo "Editing server: $_arg_name (current values in brackets)"
		read -rp "IP address [$sshm0_server_ip]: " _arg_ip
		_arg_ip="${_arg_ip:-$sshm0_server_ip}"
		read -rp "User [$sshm0_server_user]: " _arg_user
		_arg_user="${_arg_user:-$sshm0_server_user}"
		read -rp "Auth method (key/password) [$sshm0_server_auth]: " _arg_auth
		_arg_auth="${_arg_auth:-$sshm0_server_auth}"
		if [ "$_arg_auth" = "key" ]; then
			read -rp "Key path [$sshm0_server_key]: " _arg_key
			_arg_key="${_arg_key:-$sshm0_server_key}"
		else
			read -rp "Password [*****]: " _arg_password
		fi
		read -rp "Port [$sshm0_server_port]: " _arg_port
		_arg_port="${_arg_port:-$sshm0_server_port}"
		read -rp "Tags (comma-separated) [$(IFS=,; echo "${sshm0_server_tags[*]}")]: " _arg_tag
		_current_tags="$(IFS=,; echo "${sshm0_server_tags[*]}")"
		_arg_tag="${_arg_tag:-$_current_tags}"
		read -rp "Group [$sshm0_server_group]: " _arg_group
		_arg_group="${_arg_group:-$sshm0_server_group}"
		read -rp "Proxy server [${sshm0_server_proxy:-none}]: " _arg_proxy
		_arg_proxy="${_arg_proxy:-$sshm0_server_proxy}"
		read -rp "Timeout in seconds [${sshm0_server_timeout:-10}]: " _arg_timeout
		_arg_timeout="${_arg_timeout:-${sshm0_server_timeout:-10}}"
		echo ""
	fi
	# Resolve final field values: supplied arg overrides existing value.
	# IMPORTANT: edit writes the config in place (mirroring add's %q serialization)
	# rather than round-tripping through add, so that:
	#   - the stored (encrypted) password is never re-encrypted (which would break auth),
	#   - fields add has no options for (cd, exec_before) are preserved.
	if [ -n "$_arg_ip" ]; then sshm0_server_ip="$_arg_ip"; fi
	if [ -n "$_arg_user" ]; then sshm0_server_user="$_arg_user"; fi
	_final_port="${_arg_port:-$sshm0_server_port}"
	_final_auth="${_arg_auth:-$sshm0_server_auth}"
	_final_key="${_arg_key:-$sshm0_server_key}"
	_final_timeout="${_arg_timeout:-${sshm0_server_timeout:-10}}"

	# Password: re-encrypt ONLY when a new password was supplied; otherwise keep the
	# existing ciphertext verbatim so it decrypts correctly later.
	if [ -n "$_arg_password" ]; then
		_final_password="$(sshm0_encrypt_password "$_arg_password")"
	else
		_final_password="$sshm0_server_password"
	fi

	# Tags: --tag replaces the whole set when supplied; otherwise keep existing.
	if [ -n "$_arg_tag" ]; then
		sshm0_server_tags=()
		IFS=',' read -ra _tag_parts <<< "$_arg_tag"
		for _tp in "${_tag_parts[@]}"; do
			_tp="${_tp# }"; _tp="${_tp% }"
			[ -z "$_tp" ] && continue
			sshm0_server_tags+=("$_tp")
		done
	fi
	if [ -n "$_arg_group" ]; then sshm0_server_group="$_arg_group"; fi
	if [ -n "$_arg_proxy" ]; then sshm0_server_proxy="$_arg_proxy"; fi

	sshm0_validate_server "$sshm0_server_ip" "$_final_port" "$sshm0_server_user" "$_final_auth" "$_final_key" "$_final_timeout" || exit 1

	# Serialize the config using the same %q escaping as `add`, preserving every field.
	_cfgpath="$(sshm0_server_config_path "$_arg_name")" || exit 1
	_tmpcfg="$(mktemp)" || die "Failed to create temp file" 1
	{
		printf '# sshm0 server config\n'
		printf 'sshm0_server_ip=%s\n'      "$(printf '%q' "$sshm0_server_ip")"
		printf 'sshm0_server_user=%s\n'    "$(printf '%q' "$sshm0_server_user")"
		printf 'sshm0_server_port=%s\n'    "$(printf '%q' "$_final_port")"
		printf 'sshm0_server_auth=%s\n'    "$(printf '%q' "$_final_auth")"
		printf 'sshm0_server_password=%s\n' "$(printf '%q' "$_final_password")"
		printf 'sshm0_server_key=%s\n'     "$(printf '%q' "$_final_key")"
		printf 'sshm0_server_timeout=%s\n' "$(printf '%q' "$_final_timeout")"
		# cd is preserved from the loaded server (add has no option for it)
		printf 'sshm0_server_cd=%s\n' "$(printf '%q' "$sshm0_server_cd")"
		# exec_before and tags are arrays; serialize each element with %q inside ( ... ).
		# Both are preserved from the loaded server unless a flag overrides tags.
		if [ "${#sshm0_server_exec_before[@]}" -gt 0 ]; then
			printf 'sshm0_server_exec_before=('
			for _eb in "${sshm0_server_exec_before[@]}"; do printf '%q ' "$_eb"; done
			printf ')\n'
		else
			printf 'sshm0_server_exec_before=()\n'
		fi
		if [ "${#sshm0_server_tags[@]}" -gt 0 ]; then
			printf 'sshm0_server_tags=('
			for _t in "${sshm0_server_tags[@]}"; do printf '%q ' "$_t"; done
			printf ')\n'
		else
			printf 'sshm0_server_tags=()\n'
		fi
		printf 'sshm0_server_group=%s\n' "$(printf '%q' "$sshm0_server_group")"
		printf 'sshm0_server_proxy=%s\n' "$(printf '%q' "$sshm0_server_proxy")"
	} > "$_tmpcfg" || { rm -f "$_tmpcfg"; die "Failed to write server config" 1; }
	chmod 600 "$_tmpcfg" || { rm -f "$_tmpcfg"; die "Failed to chmod server config" 1; }
	mv "$_tmpcfg" "$_cfgpath" || { rm -f "$_tmpcfg"; die "Failed to save server config" 1; }
	log "Updated server $_arg_name" 1

	if [ "$_arg_connect" != "off" ]; then
		"$_SCRIPT_DIR/../sshm0" connect "$_arg_name";
	fi
else
  die "Server '$_arg_name' not found." 1;
fi
