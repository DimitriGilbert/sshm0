#!/bin/bash

# @parseArger-begin
# @parseArger-help "view and edit global configuration" --option "help" --short-option "h"
# @parseArger-version "0.3.1" --option "version" --short-option "v"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
# @parseArger-source $SSHM0_ROOT_DIR/bin/utils
source "$SSHM0_ROOT_DIR/bin/utils";
# @parseArger-declarations
# @parseArger pos action "action to perform" --one-of "list" --one-of "get" --one-of "set" --one-of "plugins" --optional
# @parseArger pos key "config key (for get/set)" --optional
# @parseArger pos value "config value (for set)" --optional
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options=''
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
_optional_positionals+=("_arg_action");
_arg_action="";
_one_of_arg_action=("list" "get" "set" "plugins" );
_arg_key="";
_optional_positionals+=("_arg_key");
_arg_value="";
_optional_positionals+=("_arg_value");
# OPTIONALS ARGUMENTS
# FLAGS
# NESTED
# LEFTOVERS
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "view and edit global configuration:"
	echo -e "	action: action to perform [one of 'list' 'get' 'set' 'plugins']"
	echo -e "	key: config key (for get/set)"
	echo -e "	value: config value (for set)"
	echo -e "Usage :
	$0 [action] [key] [value]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="\033[0;31m";
				;;
			-2)
				_arg_COLOR="\033[0;33m";
				;;
			-1)
				_arg_COLOR="\033[1;33m";
				;;
			1)
				_arg_COLOR="\033[0;32m";
				;;
			2)
				_arg_COLOR="\033[1;36m";
				;;
			3)
				_arg_COLOR="\033[0;36m";
				;;
			*)
				_arg_COLOR="\033[0m";
				;;
		esac
		echo -e "${_arg_COLOR}${_arg_msg}\033[0m";
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			-v|--version)
				print_version;
				exit 0;
				;;
			-v*)
				print_version;
				exit 0;
				;;
			--verbose)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level + 1))";
					else
						_verbose_level="$2";
						shift;
					fi
					;;
				--quiet)
					if [ $# -lt 2 ];then
						_verbose_level="$((_verbose_level - 1))";
					else
						_verbose_level="-$2";
						shift;
					fi
					;;
				
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string="action"
	if [ "${_positionals_count}" -gt 3 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 3 (namely: action key value), but got ${_positionals_count} (the last one was: '${_last_positional}').\n\t${_positionals[*]}" 1
	fi
	if [ "${_positionals_count}" -lt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: Not enough positional arguments - we require at least 0 (namely: $_required_args_string), but got only ${_positionals_count}.
	${_positionals[*]}" 1;
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names="_arg_action _arg_key _arg_value ";
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		if ! [[ "$_positional_name" =~ "_arg_leftovers" ]];then
			eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		fi
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	action: ${_arg_action}";
	echo -e "	key: ${_arg_key}";
	echo -e "	value: ${_arg_value}";

}


print_version()
{
	echo "0.3.1";
}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 1 "${_positionals[@]}";
_arg_action="${_arg_action:-list}";
trap on_interrupt INT;



# @parseArger-parsing-end
# print_debug "$@"
# @parseArger-end

_config_file="$SSHM0_CONFIG_DIR/config"

if [ ! -f "$_config_file" ]; then
	die "Config file not found at $_config_file" 1
fi

declare -A sshm0_plugins
source "$_config_file"

case "${_arg_action}" in
	list)
		while IFS= read -r _line; do
			case "$_line" in
				declare\ -A*|"#"*|"")
					continue
					;;
				*=*)
					_var_name="${_line%%=*}"
					_var_value="${_line#*=}"
					echo "${_var_name}=${_var_value}"
					;;
			esac
		done < "$_config_file"
		if [ "${#sshm0_plugins[@]}" -gt 0 ]; then
			echo ""
			echo "plugins:"
			for _pname in "${!sshm0_plugins[@]}"; do
				echo "  ${_pname} -> ${sshm0_plugins[$_pname]}"
			done
		fi
		;;
	get)
		if [ -z "$_arg_key" ]; then
			die "Key is required for 'get' action" 1
		fi
		if ! [[ "$_arg_key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
			die "Invalid config key: $_arg_key" 1
		fi
		_found=0
		while IFS= read -r _line; do
			case "$_line" in
				declare\ -A*|"#"*|"")
					continue
					;;
				*=*)
					_var_name="${_line%%=*}"
					if [ "$_var_name" = "$_arg_key" ]; then
						_var_value="${_line#*=}"
						echo "$_var_value"
						_found=1
						break
					fi
					;;
			esac
		done < "$_config_file"
		if [ "$_found" -eq 0 ]; then
			_eval_val="${!_arg_key}"
			if [ -n "$_eval_val" ]; then
				echo "$_eval_val"
			else
				echo "Key '$_arg_key' not found" >&2
				exit 1
			fi
		fi
		;;
	set)
		if [ -z "$_arg_key" ]; then
			die "Key is required for 'set' action" 1
		fi
		if ! [[ "$_arg_key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
			die "Invalid config key: $_arg_key" 1
		fi
		if [ -z "$_arg_value" ]; then
			die "Value is required for 'set' action" 1
		fi
		_entry="${_arg_key}=$(printf '%q' "$_arg_value")"
		_tmp_config="$(mktemp)" || die "Failed to create temporary file" 1
		_found=0
		while IFS= read -r _line; do
			case "$_line" in
				"$_arg_key="*)
					printf '%s\n' "$_entry" >> "$_tmp_config" || { rm -f "$_tmp_config"; die "Failed to write config" 1; }
					_found=1
					;;
				*)
					printf '%s\n' "$_line" >> "$_tmp_config" || { rm -f "$_tmp_config"; die "Failed to write config" 1; }
					;;
			esac
		done < "$_config_file"
		if [ "$_found" -eq 0 ]; then
			printf '%s\n' "$_entry" >> "$_tmp_config" || { rm -f "$_tmp_config"; die "Failed to write config" 1; }
		fi
		if mv "$_tmp_config" "$_config_file"; then
			log "Set ${_arg_key}=${_arg_value}" 1
		else
			rm -f "$_tmp_config"
			die "Failed to update config" 1
		fi
		;;
	plugins)
		if [ "${#sshm0_plugins[@]}" -eq 0 ]; then
			echo "No plugins registered"
		else
			for _pname in "${!sshm0_plugins[@]}"; do
				echo "${_pname} -> ${sshm0_plugins[$_pname]}"
			done
		fi
		;;
esac
